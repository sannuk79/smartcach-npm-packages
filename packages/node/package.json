{
  "name": "smartcache-pro",
  "version": "0.1.2",
  "description": "Universal Cache Management with LRU + TTL + Priority Eviction - Production Ready for 10K-100M entries. Hybrid L1+L2 caching with Redis/Disk support.",
  "main": "./dist/index.min.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && npm run minify",
    "minify": "terser dist/index.js --output dist/index.min.js --compress --mangle && terser dist/hybrid.js --output dist/hybrid.min.js --compress --mangle",
    "test": "jest",
    "stress-test": "node stress-tests.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "cache",
    "caching",
    "lru",
    "ttl",
    "memory",
    "eviction",
    "performance",
    "hybrid",
    "redis",
    "production",
    "lru-cache",
    "ttl-cache",
    "in-memory",
    "node-cache",
    "smart-cache",
    "cache-manager",
    "data-cache",
    "api-cache",
    "response-cache",
    "session-cache",
    "distributed-cache",
    "cluster-cache",
    "high-performance",
    "scalable",
    "enterprise",
    "multi-level",
    "tiered-cache",
    "object-cache",
    "key-value",
    "storage",
    "optimization",
    "speed",
    "fast",
    "efficient"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smartcache/smartcache.git"
  },
  "homepage": "https://github.com/smartcache/smartcache#readme",
  "bugs": {
    "url": "https://github.com/smartcache/smartcache/issues"
  },
  "peerDependencies": {
    "redis": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "terser": "^5.46.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
